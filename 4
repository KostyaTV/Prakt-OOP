class Hunter:
    def __init__(self, name):
        self.__name = name
        self.__hp = 100
        self.__weapons = []

    def get_name(self):
        return self.__name

    def get_hp(self):
        return self.__hp

    def set_hp(self, value):
        self.__name = value
        if self.__hp < 0:
            self.__hp = 0

    def add_weapon(self, weapon):
        self.__weapons.append(weapon)

    def show_inventory(self):
        for i in range(len(self.__weapons)):
            print(f"{i}. {self.__weapons[i]}")

    def attack(self, weapon_index, monster):
        weapon = self.__weapons[weapon_index]
        print(f"{self.__name} атакует {monster.name}, используя {weapon.name}...")
        weapon.use(monster)

    def is_alive(self):
        return self.__hp > 0
